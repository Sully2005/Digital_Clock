0000              1   ; ISR_example.asm: a) Increments/decrements a BCD variable every half second using
0000              2   ; an ISR for timer 2; b) Generates a 2kHz square wave at pin P1.7 using
0000              3   ; an ISR for timer 0; and c) in the 'main' loop it displays the variable
0000              4   ; incremented/decremented using the ISR for timer 2 on the LCD. Also resets it to
0000              5   ; zero if the 'CLEAR' push button connected to P1.5 is pressed.
                  7   $LIST
0000              9   ; N76E003 pinout:
0000             10   ; -------
0000             11   ; PWM2/IC6/T0/AIN4/P0.5 -|1 20|- P0.4/AIN5/STADC/PWM3/IC3
0000             12   ; TXD/AIN3/P0.6 -|2 19|- P0.3/PWM5/IC5/AIN6
0000             13   ; RXD/AIN2/P0.7 -|3 18|- P0.2/ICPCK/OCDCK/RXD_1/[SCL]
0000             14   ; RST/P2.0 -|4 17|- P0.1/PWM4/IC4/MISO
0000             15   ; INT0/OSCIN/AIN1/P3.0 -|5 16|- P0.0/PWM3/IC3/MOSI/T1
0000             16   ; INT1/AIN0/P1.7 -|6 15|- P1.0/PWM2/IC2/SPCLK
0000             17   ; GND -|7 14|- P1.1/PWM1/IC1/AIN7/CLO
0000             18   ;[SDA]/TXD_1/ICPDA/OCDDA/P1.6 -|8 13|- P1.2/PWM0/IC0
0000             19   ; VDD -|9 12|- P1.3/SCL/[STADC]
0000             20   ; PWM5/IC7/SS/P1.5 -|10 11|- P1.4/SDA/FB/PWM1
0000             21   ; -------
0000             22   ;
0000             23   CLK EQU 16600000 ; Microcontroller system frequency in Hz
0000             24   TIMER0_RATE EQU 4096 ; 2048Hz squarewave (peak amplitude of CEM-1203 speaker)
0000             25   TIMER0_RELOAD EQU ((65536-(CLK/TIMER0_RATE)))
0000             26   TIMER2_RATE EQU 1000 ; 1000Hz, for a timer tick of 1ms
0000             27   TIMER2_RELOAD EQU ((65536-(CLK/TIMER2_RATE)))
0000             28   NOTE_C5 EQU (65536 - (CLK/(523*2))); Do 
0000             29   NOTE_D5 EQU (65536 - (CLK/(587*2))); Re
0000             30   NOTE_E5 EQU (65536 - (CLK/(659*2))); Mi
0000             31   NOTE_F5 EQU (65536 - (CLK/(698*2))) ; Fa
0000             32   NOTE_G5 EQU (65536 - (CLK/(784*2))); So
0000             33   HOUR_BUTTON equ P1.5
0000             34   SET_TIME_MODE equ P1.6
0000             35   SOUND_OUT equ P1.7
0000             36   MINUTE_BUTTON equ P3.0
0000             37   SECOND_BUTTON equ P1.2
0000             38   SET_ALARM_MODE equ P1.1
0000             39   PIANO_BUTTON equ P1.0
0000             40   ALARM_LED equ P0.4
0000             41   ; Reset vector
0000             42   org 0x0000
0000 0201D7      43   ljmp main
0003             44   ; External interrupt 0 vector (not used in this code)
0003             45   org 0x0003
0003 32          46   reti
0004             47   ; Timer/Counter 0 overflow interrupt vector
000B             48   org 0x000B
000B 02012A      49   ljmp Timer0_ISR
000E             50   ; External interrupt 1 vector (not used in this code)
0013             51   org 0x0013
0013 32          52   reti
0014             53   ; Timer/Counter 1 overflow interrupt vector (not used in this code)
001B             54   org 0x001B
001B 32          55   reti
001C             56   ; Serial port receive/transmit interrupt vector (not used in this code)
0023             57   org 0x0023
0023 32          58   reti
0024             59   ; Timer/Counter 2 overflow interrupt vector
002B             60   org 0x002B
002B 020154      61   ljmp Timer2_ISR
002E             62   ; In the 8051 we can define direct access variables starting at location 0x30 up to
002E             63   ;location 0x7F
0030             64   dseg at 0x30
0030             65   Count1ms: ds 2 ; Used to determine when half second has passed
0032             66   BCD_counter: ds 1
0033             67   minutes_counter: ds 1
0034             68   hour_counter: ds 1
0035             69   AM_check: ds 1
0036             70   Alarm_hour: ds 1
0037             71   Alarm_minutes: ds 1
0038             72   Alarm_Am_check: ds 1
0039             73   Alarm_off_flag: ds 1
003A             74   current_note_h: ds 1
003B             75   current_note_l: ds 1
003C             76   
003C             77    ; The BCD counter incrememted in the ISR and displayed in the
003C             78   ;main loop
003C             79   ; In the 8051 we have variables that are 1-bit in size. We can use the setb, clr,
003C             80   ;jb, and jnb
003C             81   ; instructions with these variables. This is how you define a 1-bit variable:
0000             82   bseg
0000             83   half_seconds_flag: dbit 1 ; Set to one in the ISR every time 500 ms had passed
002E             84   cseg
002E             85   ; These 'equ' must match the hardware wiring
002E             86   LCD_RS equ P1.3
002E             87   ;LCD_RW equ PX.X ; Not used in this code, connect the pin to GND
002E             88   LCD_E equ P1.4
002E             89   LCD_D4 equ P0.0
002E             90   LCD_D5 equ P0.1
002E             91   LCD_D6 equ P0.2
002E             92   LCD_D7 equ P0.3
                 94   $LIST
00E2             96   ; 1234567890123456 <- This helps determine the location of the counter
00E2 54696D65    97   Initial_Message: db 'Time:    :  :', 0
     3A202020
     203A2020
     3A00
00F0 416C6172    98   Bottom_Message: db 'Alarm:   :', 0
     6D3A2020
     203A00
00FB 2D2D2050    99   Piano_Message: db '-- PIANO MODE --', 0
     49414E4F
     204D4F44
     45202D2D
     00
010C 2000       100   Blank_Line: db ' ', 0
010E            101   ;---------------------------------;
010E            102   ; Routine to initialize the ISR ;
010E            103   ; for timer 0 ;
010E            104   ;---------------------------------;
010E            105   Timer0_Init:
010E 438E08     106   orl CKCON, #0b00001000 ; Input for timer 0 is sysclk/1
0111 E589       107   mov a, TMOD
0113 54F0       108   anl a, #0xf0 ; 11110000 Clear the bits for timer 0
0115 4401       109   orl a, #0x01 ; 00000001 Configure timer 0 as 16-timer
0117 F589       110   mov TMOD, a
0119 753AF0     111   mov current_note_h, #high(TIMER0_RELOAD)
011C 753B2C     112   mov current_note_l, #low(TIMER0_RELOAD)
011F 853A8C     113   mov TH0, current_note_h
0122 853B8A     114   mov TL0, current_note_l
0125            115   ; Enable the timer and interrupts
0125 D2A9       116   setb ET0 ; Enable timer 0 interrupt
0127 C28C       117   clr TR0 ; Start timer 0
0129 22         118   ret
012A            119   ;---------------------------------;
012A            120   ; ISR for timer 0. Set to execute;
012A            121   ; every 1/4096Hz to generate a ;
012A            122   ; 2048 Hz wave at pin SOUND_OUT ;
012A            123   ;---------------------------------;
012A            124   Timer0_ISR:
012A            125   ;clr TF0 ; According to the data sheet this is done for us already.
012A            126   ; Timer 0 doesn't have 16-bit auto-reload, so
012A C28C       127   clr TR0
012C 853A8C     128   mov TH0, current_note_h
012F 853B8A     129   mov TL0, current_note_l
0132 D28C       130   setb TR0
0134 B297       131   cpl SOUND_OUT ; Connect speaker the pin assigned to 'SOUND_OUT'!
0136 32         132   reti
0137            133   ;---------------------------------;
0137            134   ; Routine to initialize the ISR ;
0137            135   ; for timer 2 ;
0137            136   ;---------------------------------;
0137            137   Timer2_Init:
0137 75C800     138   mov T2CON, #0 ; Stop timer/counter. Autoreload mode.
013A 75CDBF     139   mov TH2, #high(TIMER2_RELOAD)
013D 75CC28     140   mov TL2, #low(TIMER2_RELOAD)
0140            141   ; Set the reload value
0140 43C980     142   orl T2MOD, #0x80 ; Enable timer 2 autoreload
0143 75CBBF     143   mov RCMP2H, #high(TIMER2_RELOAD)
0146 75CA28     144   mov RCMP2L, #low(TIMER2_RELOAD)
0149            145   ; Init One millisecond interrupt counter. It is a 16-bit variable made with two 8-bit parts
0149 E4         146   clr a
014A F530       147   mov Count1ms+0, a
014C F531       148   mov Count1ms+1, a
014E            149   ; Enable the timer and interrupts
014E 439B80     150   orl EIE, #0x80 ; Enable timer 2 interrupt ET2=1
0151 D2CA       151   setb TR2 ; Enable timer 2
0153 22         152   ret
0154            153   ;---------------------------------;
0154            154   ; ISR for timer 2 ;
0154            155   ;---------------------------------;
0154            156   Timer2_ISR:
0154 C2CF       157   clr TF2 ; Timer 2 doesn't clear TF2 automatically. Do it in the ISR. It is bit addressable.
0156            158   ;cpl P0.4 ; To check the interrupt rate with oscilloscope. It must be precisely a 1 ms pulse.
0156            159   ; The two registers used in the ISR must be saved in the stack
0156 C0E0       160   push acc
0158 C0D0       161   push psw
015A            162   ; Increment the 16-bit one mili second counter
015A 0530       163   inc Count1ms+0 ; Increment the low 8-bits first
015C E530       164   mov a, Count1ms+0 ; If the low 8-bits overflow, then increment high 8-bits
015E 7002       165   jnz Inc_Done
0160 0531       166   inc Count1ms+1
0162            167   
0162            168   Inc_Done:
0162            169   ; Check if half second has passed
0162 E530       170   mov a, Count1ms+0
0164 B4E812     171   cjne a, #low(1000), check_led_flash ; Warning: this instruction changes the carry flag!
0167 E531       172   mov a, Count1ms+1
0169 B4030D     173   cjne a, #high(1000), check_led_flash
016C            174   ; 1000 milliseconds have passed. Set a flag so the main program knows
016C D200       175   setb half_seconds_flag ; Let the main program know half second had passed
016E            176    ; Enable/disable timer/counter 0. This line creates a beep-silence-
016E            177   ;beep-silence sound.
016E            178   ; Reset to zero the milli-seconds counter, it is a 16-bit variable
016E E4         179   clr a
016F F530       180   mov Count1ms+0, a
0171 F531       181   mov Count1ms+1, a
0173            182   ; Increment the BCD counter
0173 E532       183   mov a, BCD_counter
0175 2401       184   add a, #0x01
0177 8013       185   sjmp Timer2_ISR_da
0179            186   
0179            187   check_led_flash:
0179 E539       188   mov a, Alarm_off_flag
017B B4010C     189   cjne a, #0x01, skip_led
017E            190   
017E E530       191   mov a, Count1ms+0
0180 B4F407     192   cjne a, #low(500), skip_led
0183 E531       193   mov a, Count1ms+1
0185 B40102     194   cjne a, #high(500), skip_led
0188            195   
0188 B284       196   cpl ALARM_LED
018A            197   
018A            198   
018A            199   skip_led:
018A 8046       200   sjmp Timer2_ISR_done
018C            201   
018C            202   Timer2_ISR_da:
018C D4         203   da a ; Decimal adjust instruction. Check datasheet for more details!
018D F532       204   mov BCD_counter, a
018F            205   
018F E532       206   mov a, BCD_counter
0191 B4603E     207   cjne a, #0x60, Timer2_ISR_done
0194 753200     208   mov BCD_counter, #0
0197 E533       209   mov a, minutes_counter
0199 2401       210   add a, #0x01
019B D4         211   da a
019C F533       212   mov minutes_counter, a
019E E533       213   mov a, minutes_counter
01A0            214   
01A0 B4602F     215   cjne a, #0x60, Timer2_ISR_done
01A3 753200     216   mov BCD_counter, #0
01A6 753300     217   mov minutes_counter, #0
01A9 E534       218   mov a, hour_counter
01AB 2401       219   add a, #0x01
01AD D4         220   da a
01AE F534       221   mov hour_counter, a
01B0            222   
01B0            223   ; Check if hour reached 13, reset to 1
01B0            224   
01B0 B41205     225   cjne a, #0x12, check_reset_13
01B3 1201C0     226   lcall toggle_Am1
01B6 801A       227   sjmp Timer2_ISR_done
01B8            228   
01B8            229   
01B8            230   check_reset_13:
01B8 B41317     231   cjne a, #0x13, Timer2_ISR_done
01BB 753401     232   mov hour_counter, #0x01
01BE 8012       233   sjmp Timer2_ISR_done
01C0            234   
01C0            235   toggle_AM1:
01C0 C0E0       236   push acc
01C2 E535       237   mov a, AM_check
01C4 B44105     238   cjne a, #'A', set_A1
01C7 753550     239   mov AM_check, #'P'
01CA 8003       240   sjmp toggle_finish1
01CC            241   
01CC            242   set_A1:
01CC 753541     243   mov AM_check, #'A'
01CF            244   toggle_finish1:
01CF D0E0       245   pop acc
01D1 22         246   ret
01D2            247   
01D2            248   
01D2            249   Timer2_ISR_done:
01D2 D0D0       250   pop psw
01D4 D0E0       251   pop acc
01D6 32         252   reti
